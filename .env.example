# ─── Database ───
# Local: Use Neon (https://neon.tech) — grátis, 500MB
# Produção: Railway ou Vercel fornecerão a URL automaticamente
DATABASE_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/dyvio?sslmode=require"

# ─── NextAuth ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-por-um-hash-seguro-exemplo-openssl-rand-base64-32"

# ─── Google OAuth (opcional) ───
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"